{
  "name": "Aeryn",
  "type": "dark",
  "colors": {
    "foreground": "#D6D3C0",
    "descriptionForeground": "#9AA184",
    "errorForeground": "#CE7B57",
    "focusBorder": "#818B6B99",
    "selection.background": "#818B6B55",
    "textLink.foreground": "#818B6B",
    "textLink.activeForeground": "#F3C892",

    "activityBar.background": "#131714",
    "activityBar.foreground": "#E4DFC9",
    "activityBar.inactiveForeground": "#8C8975",
    "activityBarBadge.background": "#818B6B",
    "activityBarBadge.foreground": "#131714",

    "sideBar.background": "#131714",
    "sideBar.foreground": "#D6D3C0",
    "sideBar.border": "#232B24",
    "sideBarTitle.foreground": "#E4DFC9",
    "sideBarSectionHeader.background": "#1B211C",
    "sideBarSectionHeader.foreground": "#D6D3C0",

    "editor.background": "#131714",
    "editor.foreground": "#D6D3C0",
    "editorLineNumber.foreground": "#798A51",
    "editorLineNumber.activeForeground": "#818B6B",
    "editorCursor.foreground": "#F3C892",
    "editor.selectionBackground": "#818B6B44",
    "editor.inactiveSelectionBackground": "#798A5133",
    "editor.lineHighlightBackground": "#1B211C",
    "editorIndentGuide.background1": "#232B24",
    "editorIndentGuide.activeBackground1": "#798A51",
    "editorWhitespace.foreground": "#232B24",

    "editorWidget.background": "#1B211C",
    "editorWidget.foreground": "#D6D3C0",
    "editorWidget.border": "#232B24",
    "editorSuggestWidget.background": "#1B211C",
    "editorSuggestWidget.foreground": "#D6D3C0",
    "editorSuggestWidget.selectedBackground": "#232B24",
    "editorSuggestWidget.highlightForeground": "#F3C892",

    "panel.background": "#131714",
    "panel.border": "#232B24",
    "terminal.background": "#131714",
    "terminal.foreground": "#D6D3C0",
    "terminalCursor.foreground": "#F3C892",
    "terminal.ansiBlack": "#131714",
    "terminal.ansiRed": "#CE7B57",
    "terminal.ansiGreen": "#818B6B",
    "terminal.ansiYellow": "#F3C892",
    "terminal.ansiBlue": "#798A51",
    "terminal.ansiMagenta": "#8C8975",
    "terminal.ansiCyan": "#7FA48C",
    "terminal.ansiWhite": "#D6D3C0",
    "terminal.ansiBrightBlack": "#1B211C",
    "terminal.ansiBrightRed": "#E09A78",
    "terminal.ansiBrightGreen": "#AAB988",
    "terminal.ansiBrightYellow": "#E4DFC9",
    "terminal.ansiBrightBlue": "#929F75",
    "terminal.ansiBrightMagenta": "#9AA184",
    "terminal.ansiBrightCyan": "#8FB8A3",
    "terminal.ansiBrightWhite": "#F0EDDD",

    "statusBar.background": "#1B211C",
    "statusBar.foreground": "#D6D3C0",
    "statusBar.border": "#232B24",
    "statusBarItem.remoteBackground": "#818B6B",
    "statusBarItem.remoteForeground": "#131714",
    "titleBar.activeBackground": "#131714",
    "titleBar.activeForeground": "#E4DFC9",
    "titleBar.inactiveBackground": "#131714",
    "titleBar.inactiveForeground": "#8C8975",

    "button.background": "#798A51",
    "button.foreground": "#F0EDDD",
    "button.hoverBackground": "#818B6B",
    "input.background": "#1B211C",
    "input.foreground": "#D6D3C0",
    "input.border": "#232B24",
    "dropdown.background": "#1B211C",
    "dropdown.foreground": "#D6D3C0",
    "dropdown.border": "#232B24",

    "list.activeSelectionBackground": "#818B6B33",
    "list.activeSelectionForeground": "#F0EDDD",
    "list.hoverBackground": "#1B211C",
    "list.highlightForeground": "#F3C892",
    "list.inactiveSelectionBackground": "#798A5122"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#8C8975", "fontStyle": "italic" } },
    { "scope": ["string", "markup.inline.raw.string"], "settings": { "foreground": "#818B6B" } },
    { "scope": ["constant.numeric", "constant.language", "constant.character"], "settings": { "foreground": "#F3C892" } },
    { "scope": ["keyword", "storage", "storage.type"], "settings": { "foreground": "#9AA184" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#929F75" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#E4DFC9" } },
    { "scope": ["variable", "entity.name.variable", "support.variable"], "settings": { "foreground": "#D6D3C0" } },
    { "scope": ["entity.other.attribute-name", "variable.parameter"], "settings": { "foreground": "#F0EDDD" } },
    { "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#8FB8A3" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#F0EDDD", "fontStyle": "bold" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#F3C892" } },
    { "scope": ["markup.deleted", "invalid"], "settings": { "foreground": "#CE7B57" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#818B6B" } }
  ]
}

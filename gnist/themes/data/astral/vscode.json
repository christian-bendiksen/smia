{
  "name": "Astral",
  "type": "dark",
  "colors": {
    "foreground": "#c8d3f5",
    "descriptionForeground": "#828bb8",
    "errorForeground": "#ff757f",
    "focusBorder": "#82aaff99",
    "selection.background": "#82aaff55",
    "textLink.foreground": "#82aaff",
    "textLink.activeForeground": "#86e1fc",

    "activityBar.background": "#0f111a",
    "activityBar.foreground": "#ffd8ab",
    "activityBar.inactiveForeground": "#828bb8",
    "activityBarBadge.background": "#82aaff",
    "activityBarBadge.foreground": "#0f111a",

    "sideBar.background": "#0f111a",
    "sideBar.foreground": "#c8d3f5",
    "sideBar.border": "#1e2235",
    "sideBarTitle.foreground": "#ffd8ab",
    "sideBarSectionHeader.background": "#161928",
    "sideBarSectionHeader.foreground": "#c8d3f5",

    "editor.background": "#0f111a",
    "editor.foreground": "#c8d3f5",
    "editorLineNumber.foreground": "#828bb8",
    "editorLineNumber.activeForeground": "#82aaff",
    "editorCursor.foreground": "#86e1fc",
    "editor.selectionBackground": "#82aaff44",
    "editor.inactiveSelectionBackground": "#444a7355",
    "editor.lineHighlightBackground": "#161928",
    "editorIndentGuide.background1": "#1e2235",
    "editorIndentGuide.activeBackground1": "#444a73",
    "editorWhitespace.foreground": "#1e2235",

    "editorWidget.background": "#161928",
    "editorWidget.foreground": "#c8d3f5",
    "editorWidget.border": "#1e2235",
    "editorSuggestWidget.background": "#161928",
    "editorSuggestWidget.foreground": "#c8d3f5",
    "editorSuggestWidget.selectedBackground": "#262b42",
    "editorSuggestWidget.highlightForeground": "#ffc777",

    "panel.background": "#0f111a",
    "panel.border": "#1e2235",
    "terminal.background": "#0f111a",
    "terminal.foreground": "#c8d3f5",
    "terminalCursor.foreground": "#86e1fc",
    "terminal.ansiBlack": "#1b1e2d",
    "terminal.ansiRed": "#ff757f",
    "terminal.ansiGreen": "#c3e88d",
    "terminal.ansiYellow": "#ffc777",
    "terminal.ansiBlue": "#82aaff",
    "terminal.ansiMagenta": "#c099ff",
    "terminal.ansiCyan": "#86e1fc",
    "terminal.ansiWhite": "#c8d3f5",
    "terminal.ansiBrightBlack": "#444a73",
    "terminal.ansiBrightRed": "#ff8d94",
    "terminal.ansiBrightGreen": "#c7fb6d",
    "terminal.ansiBrightYellow": "#ffd8ab",
    "terminal.ansiBrightBlue": "#9ab8ff",
    "terminal.ansiBrightMagenta": "#caabff",
    "terminal.ansiBrightCyan": "#b2ebff",
    "terminal.ansiBrightWhite": "#ffffff",

    "statusBar.background": "#161928",
    "statusBar.foreground": "#c8d3f5",
    "statusBar.border": "#1e2235",
    "statusBarItem.remoteBackground": "#82aaff",
    "statusBarItem.remoteForeground": "#0f111a",
    "titleBar.activeBackground": "#0f111a",
    "titleBar.activeForeground": "#ffd8ab",
    "titleBar.inactiveBackground": "#0f111a",
    "titleBar.inactiveForeground": "#828bb8",

    "button.background": "#82aaff",
    "button.foreground": "#0f111a",
    "button.hoverBackground": "#9ab8ff",
    "input.background": "#161928",
    "input.foreground": "#c8d3f5",
    "input.border": "#1e2235",
    "dropdown.background": "#161928",
    "dropdown.foreground": "#c8d3f5",
    "dropdown.border": "#1e2235",

    "list.activeSelectionBackground": "#82aaff33",
    "list.activeSelectionForeground": "#ffffff",
    "list.hoverBackground": "#161928",
    "list.highlightForeground": "#ffc777",
    "list.inactiveSelectionBackground": "#444a7322"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#c099ff", "fontStyle": "italic" } },
    { "scope": ["string", "markup.inline.raw.string"], "settings": { "foreground": "#c3e88d" } },
    { "scope": ["constant.numeric", "constant.language", "constant.character"], "settings": { "foreground": "#ffc777" } },
    { "scope": ["keyword", "storage", "storage.type"], "settings": { "foreground": "#caabff" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#9ab8ff" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#ffd8ab" } },
    { "scope": ["variable", "entity.name.variable", "support.variable"], "settings": { "foreground": "#c8d3f5" } },
    { "scope": ["entity.other.attribute-name", "variable.parameter"], "settings": { "foreground": "#ffffff" } },
    { "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#c099ff" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#ffd8ab", "fontStyle": "bold" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#ffc777" } },
    { "scope": ["markup.deleted", "invalid"], "settings": { "foreground": "#ff757f" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#c3e88d" } }
  ]
}

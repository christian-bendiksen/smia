module "system-model" {
    description "Generate and inspect an AerynOS system model"

    requires {
        command "moss"
        command "sudo"
    }

    inputs {
        input "repositories" type="collection" item-type="kdl-document" {
            defaults {
                item "unstable" {
                    unstable {
                        description "AerynOS unstable repository"
                        base-uri "https://cdn.aerynos.dev/"
                        version "stream/unstable"
                        priority 0
                    }
                }
            }
        }
        input "packages" type="collection" item-type="kdl-document" {
            defaults {
                item "kernel" { linux-desktop }
                item "compositor" { mangowm }
                item "portal-backend" { xdg-desktop-portal-wlr }

                // Bootstrap tools must remain in the imported source of truth.
                item "malm" { malm }
                item "moss" { moss }
                item "git" { git }
                item "sudo" { sudo-rs }

                // Smia-Base (minimal needed)
                item "awww" { awww }
                item "waybar" { waybar }
                item "bluetui" { bluetui }
                item "brightness" { brightnessctl }
                item "btop" { btop }
                item "elephant" { elephant }
                // item "gnist" { gnist } // Not in repo yet.
                item "gpu-record" { gpu-screen-recorder }
                item "grim" { grim }
                item "helix" { helix }
                item "hypridle" { hypridle }
                item "hyprlock" { hyprlock }
                item "impala" { impala }
                item "kitty" { kitty }
                item "mako" { mako }
                item "notify-send" { libnotify }
                item "nvim" { neovim }
                item "polkit" { polkit }
                item "playerctl" { playerctl }
                item "sddm" { sddm }
                item "slurp" { slurp }
                item "swayosd" { swayosd }
                item "walker" { walker }
                item "wl-clip" { wl-clipboard-rs }
                item "wlsunset" { wlsunset }
                // item "eldritch" { aerynos-eldritch-icon-theme } // not in repo yet
                item "aeryn-base-desktop" { pkgset-aeryn-base-desktop }
                item "polkit-kde-agent" { polkit-kde-agent }
                item "xdg-desktop-portal" { xdg-desktop-portal }
                item "xdg-desktop-portal-gtk" { xdg-desktop-portal-gtk }
                item "xdg-desktop-portal-wlr" { xdg-desktop-portal-wlr }
                item "xdg-desktop-portal-gnome" { xdg-desktop-portal-gnome }
                item "xdg-utils" { xdg-utils }
                item "yaru" { yaru-icon-theme }
                item "noto" { font-noto }
                item "symbols-nerd" { font-symbols-nerd }
                item "os-artwork" { os-artwork }
                item "systemd" { systemd }
                item "linux-firmware" { linux-firmware }
                item "sof-firmware" { sof-firmware }
                item "aeryn-utilities" { pkgset-aeryn-utilities }
                item "procps" { procps }
                item "kanshi" { kanshi }
                item "nautilus" { nautilus }
                item "firefox" { firefox }
                item "build-essential" { build-essential }
                item "curl" { curl }
                item "ripgrep" { ripgrep }
                item "plymouth" { plymouth }
                item "pavucontrol" { pavucontrol }
                item "liberation-fonts" { liberation-fonts-ttf }
                item "adwaita-fonts" { adwaita-fonts }
                item "roboto-mono-nerd" { font-roboto-mono-nerd }
            }
        }
    }

    outputs {
        render "~/.local/share/smia-system-models/system-model.kdl" format="kdl" version=2 {
            repositories {
                splice "repositories"
            }
            packages {
                splice "packages"
            }
        }
        render "~/.local/share/smia-system-models/profile" format="scalar" {
            @line (ref)"profile.name"
        }
        render "~/.local/bin/smia-system-model" \
            format="text" executable=#true validate="shell" {
            @file "./smia-system-model"
        }
    }
}

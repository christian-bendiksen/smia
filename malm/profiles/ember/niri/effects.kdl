// Approximate Mango Ember's translucency, shadow, and motion in Niri.

layout {
    gaps 12

    shadow {
        on
        softness 26
        spread 6
        offset x=0 y=4
        color "#140a0233"
    }
}

window-rule {
    geometry-corner-radius 16
    clip-to-geometry true
    background-effect {
        blur true
        noise 0.03
        saturation 1.18
    }
}

window-rule {
    match is-active=true
    opacity 0.94
}
window-rule {
    match is-active=false
    opacity 0.82
}

animations {
    window-open {
        duration-ms 380
        curve "cubic-bezier" 0.22 1.0 0.36 1.0
    }
    window-close {
        duration-ms 320
        curve "cubic-bezier" 0.36 0 0.66 1.0
    }
    window-movement {
        spring damping-ratio=1.0 stiffness=600 epsilon=0.0001
    }
    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=600 epsilon=0.0001
    }
}

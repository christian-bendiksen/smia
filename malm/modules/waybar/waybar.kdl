// Profiles may replace the complete native Waybar config or stylesheet; when
// they do not, the module defaults are used. The generated wrapper imports the
// selected theme before applying global font rules.
module "waybar" {
    description "Waybar status bar: profile-replaceable config and style fragments"
    slot "bar"

    requires {
        command "waybar"
        command "playerctl"
        command "wpctl"
        command "impala"
        command "bluetui"
    }

    fragments {
        // A profile replacement supplies the complete JSONC document.
        fragment "config" format="jsonc" cardinality="one" {
            default "./config-default.jsonc"
        }
        // A profile replacement supplies the complete CSS fragment.
        fragment "style" format="gtk-css" cardinality="one" {
            default "./styles/default.css"
        }
    }

    outputs {
        render "waybar/config.jsonc" format="text" validate="jsonc" {
            @compose "config"
        }
        render "waybar/theme.css" format="text" validate="gtk-css" {
            @compose "style"
        }
        render "waybar/style.css" format="css" {
            at-rule "import" "url(theme.css)"
            "*" {
                "font-family" (f)"'{{global.font-family}}', '{{global.font-symbols}}', sans-serif"
            }
            "window#waybar.rail, window#waybar.rail *" {
                "font-family" (f)"'{{global.font-mono}}', '{{global.font-symbols}}', monospace"
            }
            "#clock" {
                "font-family" (f)"'{{global.font-mono}}', monospace"
            }
            "#custom-astral, #custom-mpris, #cpu, #network, #pulseaudio, #battery, #custom-power" {
                "font-family" (f)"'{{global.font-symbols}}'"
            }
        }
        // Profile-dependent configuration requires Waybar to restart on activation.
        render "gnist/session.d/waybar" format="line-list" {
            @comment "Generated by the `waybar` module; edits will be replaced."
            @line "restart waybar"
        }
    }
}

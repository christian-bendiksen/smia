// Selects an implementation for each portal interface. The `default` selector
// handles interfaces without an explicit entry and may contain a semicolon-
// ordered fallback list. Profiles choose capture backends for their compositor.
module "portals" {
    description "xdg-desktop-portal per-interface backend selection"
    slot "portal"

    requires {
        command "/usr/lib/xdg-desktop-portal/xdg-desktop-portal"
        when "needs-gtk-backend" {
            command "/usr/lib/xdg-desktop-portal-gtk/xdg-desktop-portal-gtk"
        }
        when "needs-wlr-backend" {
            command "/usr/lib/xdg-desktop-portal-wlr/xdg-desktop-portal-wlr"
        }
        when "needs-gnome-backend" {
            command "/usr/lib/xdg-desktop-portal-gnome/xdg-desktop-portal-gnome"
        }
        when "needs-hyprland-backend" {
            command "/usr/lib/xdg-desktop-portal-hyprland/xdg-desktop-portal-hyprland"
        }
        when "needs-kde-backend" {
            command "/usr/lib/xdg-desktop-portal-kde/xdg-desktop-portal-kde"
        }
    }

    inputs {
        // Keep requirement gates aligned with selectors because Malm
        // conditions cannot compare enum values directly.
        input "needs-gtk-backend" type="bool" default=#true
        input "needs-wlr-backend" type="bool" default=#true
        input "needs-gnome-backend" type="bool" default=#false
        input "needs-hyprland-backend" type="bool" default=#false
        input "needs-kde-backend" type="bool" default=#false
        input "default" type="enum" default="gtk" {
            values "gtk" "kde" "gnome;gtk;" "hyprland;gtk;"
        }
        input "file-chooser" type="enum" default="gtk" {
            values "gtk" "kde" "gnome"
        }
        input "notification" type="enum" default="gtk" {
            values "gtk" "kde" "gnome"
        }
        input "open-uri" type="enum" default="gtk" {
            values "gtk" "kde" "gnome"
        }
        input "screenshot" type="enum" default="wlr" {
            values "wlr" "hyprland" "gnome" "kde"
        }
        input "screen-cast" type="enum" default="wlr" {
            values "wlr" "hyprland" "gnome" "kde"
        }
        input "inhibit" type="enum" default="none" {
            values "none" "gtk" "kde" "gnome"
        }
    }

    outputs {
        render "xdg-desktop-portal/portals.conf" format="ini" {
            @comment "Generated by the `portals` module; edits will be replaced."
            @comment "Explicit interface selectors override the default backend or fallback list."
            "preferred" {
                "default" (ref)"default"
                "org.freedesktop.impl.portal.FileChooser" (ref)"file-chooser"
                "org.freedesktop.impl.portal.Notification" (ref)"notification"
                "org.freedesktop.impl.portal.OpenURI" (ref)"open-uri"
                "org.freedesktop.impl.portal.Screenshot" (ref)"screenshot"
                "org.freedesktop.impl.portal.ScreenCast" (ref)"screen-cast"
                "org.freedesktop.impl.portal.Inhibit" (ref)"inhibit"
            }
        }
    }
}

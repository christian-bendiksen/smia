// This module owns the per-profile state consumed by gnist and
// `smia-session`: profile identity, themes, reload rules, and services.
// The `theme` setting is the sole source for both default-theme and the session
// manifest.
module "gnist-runtime" {
    description "Per-profile gnist session state (profile, themes, reload table, service manifest)"
    slot "theme-runtime"

    inputs {
        input "theme"      type="string" default="aeryn"
        input "menu-theme" type="string" default="gnist-menu"

        // Stop entries are process names; extras are complete manifest lines for
        // session tasks that do not warrant a module.
        input "stop-services"  type="list" item-type="string" { default "dms" }
        input "extra-services" type="list" item-type="string"
    }

    fragments {
        // Exactly one compositor reload binding precedes the shared application
        // bindings from bindings-base.kdl.
        fragment "compositor-reload" format="kdl-v2" cardinality="one" {
            default "./reload-mango.kdl"
        }
        fragment "base-bindings" format="kdl-v2" cardinality="one" {
            default "./bindings-base.kdl"
        }
    }

    outputs {
        // The built-in profile name is authoritative for runtime state.
        render "gnist/profile" format="scalar" {
            @line (ref)"profile.name"
        }
        render "gnist/default-theme" format="scalar" {
            @line (ref)"theme"
        }
        render "gnist/menu-theme" format="scalar" {
            @line (ref)"menu-theme"
        }
        render "gnist/bindings.kdl" format="kdl" version=2 {
            @compose fragment="compositor-reload"
            @compose fragment="base-bindings"
        }
        render "gnist/session.services" format="line-list" {
            @comment "Generated by the `gnist-runtime` module; edits will be replaced."
            @comment "`smia-session` accepts these directives:"
            @comment "  theme <name>            initializes the theme; `--apply-theme` selects it explicitly"
            @comment "  theme keep              preserves the current theme; reloads it with `--apply-theme`"
            @comment "  prepare <proc> [command] starts a theme dependency unless proc is already running"
            @comment "  run <proc> [command]    starts command, or proc when omitted, unless proc is running"
            @comment "  restart <proc> [command] stops proc, waits for exit, then starts it as above"
            @comment "  stop <proc>             stops processes whose exact name is proc"
            @comment "Commands are passed to `sh -c`; proc and command are separated by whitespace."
            @line "#"
            @comment "Session services live in owner-specific session.d fragments. This core"
            @comment "manifest contains only the theme directive and session-wide cleanup."
            @line (f)"theme {{theme}}"
            @line ""
            @each "service" in="stop-services" {
                @line (f)"stop {{service}}"
            }
            @each "line" in="extra-services" {
                @line (ref)"line"
            }
        }
    }
}

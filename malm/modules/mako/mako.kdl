// Configures mako geometry and behavior. The included gnist theme owns
// notification colors.
module "mako" {
    description "Notification daemon config with typed geometry and behavior"
    slot "notifications"

    requires {
        command "mako"
    }

    inputs {
        input "anchor" type="enum" default="top-right" {
            values "top-right" "top-center" "top-left" \
                   "bottom-right" "bottom-center" "bottom-left"
        }
        input "width" type="int" default=400
        input "outer-margin" type="int" default=16
        input "margin" type="int" default=10
        input "padding" type="string" default="15,18"
        input "border-size" type="int" default=1
        input "border-radius" type="int" default=0
        input "icons" type="int" default=1
        input "max-icon-size" type="int" default=46
        input "icon-border-radius" type="int" default=0
        // The global font family is shared; this module owns only its size.
        input "font-size" type="int" default=11
        input "timeout" type="int" default=5000
        input "progress-color" type="string" default="over #82aaff66"
        input "critical-timeout" type="int" default=0
        input "critical-layer" type="enum" default="overlay" {
            values "overlay" "top" "bottom" "background"
        }
    }

    outputs {
        render "mako/config" format="ini" {
            "include" "~/.config/gnist/themes/current/mako.ini"
            "anchor" (ref)"anchor"
            "width" (ref)"width"
            "outer-margin" (ref)"outer-margin"
            "margin" (ref)"margin"
            "padding" (ref)"padding"
            "border-size" (ref)"border-size"
            "border-radius" (ref)"border-radius"
            "icons" (ref)"icons"
            "max-icon-size" (ref)"max-icon-size"
            "icon-border-radius" (ref)"icon-border-radius"
            "font" (f)"{{global.font-family}} {{font-size}}"
            "default-timeout" (ref)"timeout"
            "progress-color" (ref)"progress-color"
            "urgency=critical" {
                "default-timeout" (ref)"critical-timeout"
                "layer" (ref)"critical-layer"
            }
        }
        file "./core.ini" to="mako/core.ini"
        render "gnist/session.d/mako" format="line-list" {
            @comment "Generated by the `mako` module; edits will be replaced."
            @comment "The `makoctl reload` binding covers theme changes."
            @line "run mako"
        }
    }
}

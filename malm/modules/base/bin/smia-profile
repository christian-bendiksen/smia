#!/usr/bin/env bash

set -euo pipefail

case "${1:-}" in
    -h|--help)
        (($# == 1)) || { printf 'usage: smia-profile PROFILE\n' >&2; exit 2; }
        printf 'usage: smia-profile PROFILE\n'
        exit 0
        ;;
esac

(($# == 1)) || { printf 'usage: smia-profile PROFILE\n' >&2; exit 2; }
exec smia-profiles switch "$1"

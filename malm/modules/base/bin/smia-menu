#!/usr/bin/env bash

set -euo pipefail

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
TERMINALS_LIST="$XDG_CONFIG_HOME/xdg-terminals.list"
DESKTOP_DIRS=(
    "$HOME/.local/share/applications"
    "$HOME/.local/share/flatpak/exports/share/applications"
    /var/lib/flatpak/exports/share/applications
    /usr/local/share/applications
    /usr/share/applications
)
THEMES_DIR="$HOME/.config/gnist/themes/data"
MENU_THEME="$(cat "$XDG_CONFIG_HOME/gnist/menu-theme" 2>/dev/null || printf 'gnist-menu')"

notify() {
    command -v notify-send >/dev/null 2>&1 && notify-send "$@" || printf '%s\n' "$*" >&2
}

pick() {
    local out rc
    out="$(walker --dmenu --placeholder "$1" --theme "$MENU_THEME")"; rc=$?
    [[ $rc -eq 0 && -n "$out" ]] || return 1
    printf '%s\n' "$out"
}

desktop_field() {
    awk -v key="$2" '
        /^\[/ { in_default = ($0 == "[Desktop Entry]") }
        in_default && $0 ~ "^"key"=" {
            sub("^"key"=", "")
            print
            exit
        }
    ' "$1"
}

# Return the first whitespace-delimited token from a desktop Exec field. This
# intentionally does not implement Desktop Entry quoting or field-code parsing.
desktop_exec() {
    local exec
    exec="$(desktop_field "$1" Exec)"
    read -r bare _ <<<"$exec"
    printf '%s' "$bare"
}

# Write editor and terminal defaults for future environment-generator runs and
# update the current systemd user manager. Existing processes are unchanged.
write_defaults_env() {
    local env_dir="$XDG_CONFIG_HOME/environment.d"
    mkdir -p "$env_dir"
    local f="$env_dir/gnist-defaults.conf"
    {
        printf '# Generated by smia-menu; do not edit manually.\n'
        if [[ -n "${1:-}" ]]; then printf 'EDITOR=%s\nVISUAL=%s\n' "$1" "$1"; fi
        if [[ -n "${2:-}" ]]; then printf 'TERMINAL=%s\n' "$2"; fi
    } > "$f"
    # Update the running systemd user environment because this process does
    # not contain the new values for import-environment to read.
    if [[ -n "${1:-}" ]]; then
        systemctl --user set-environment "EDITOR=$1" "VISUAL=$1" 2>/dev/null || true
    fi
    if [[ -n "${2:-}" ]]; then
        systemctl --user set-environment "TERMINAL=$2" 2>/dev/null || true
    fi
}

list_desktops() {
    local pattern="$1"
    local seen=""
    local dir file base name
    for dir in "${DESKTOP_DIRS[@]}"; do
        [[ -d "$dir" ]] || continue
        for file in "$dir"/*.desktop; do
            [[ -r "$file" ]] || continue
            base="$(basename "$file")"
            case ":$seen:" in *":$base:"*) continue ;; esac
            grep -qE "$pattern" "$file" || continue
            [[ "$(desktop_field "$file" Hidden)" == "true" ]] && continue
            [[ "$(desktop_field "$file" NoDisplay)" == "true" ]] && continue
            name="$(desktop_field "$file" Name)"
            [[ -z "$name" ]] && name="$base"
            printf '%s|%s|%s\n' "$name" "$base" "$file"
            seen="$seen:$base"
        done
    done | sort -f
}

# Return "desktop-id|full-path" so MIME callers can use ${choice%%|*} and Exec
# callers can use the original path from ${choice#*|}.
choose_desktop() {
    local label="$1" pattern="$2"
    local choices name entry
    choices="$(list_desktops "$pattern")"
    [[ -z "$choices" ]] && { notify "smia-menu" "No candidates found for $label"; return 1; }
    name="$(printf '%s\n' "$choices" | cut -d'|' -f1 | pick "$label")" || return 1
    [[ -z "$name" ]] && return 1
    entry="$(printf '%s\n' "$choices" | awk -F'|' -v n="$name" '$1 == n { print $2 "|" $3; exit }')"
    [[ -z "$entry" ]] && return 1
    printf '%s\n' "$entry"
}

set_terminal() {
    local choice file path
    choice="$(choose_desktop "Terminal" '^Categories=.*TerminalEmulator')" || return 0
    file="${choice%%|*}"; path="${choice#*|}"
    mkdir -p "$(dirname "$TERMINALS_LIST")"
    printf '%s\n' "$file" > "$TERMINALS_LIST"
    local cmd
    cmd="$(desktop_exec "$path" 2>/dev/null || true)"
    write_defaults_env "" "${cmd:-$file}"
    notify "Default terminal" "$file"
}

set_browser() {
    local choice file
    choice="$(choose_desktop "Browser" '^MimeType=.*x-scheme-handler/https')" || return 0
    file="${choice%%|*}"
    for mime in x-scheme-handler/http x-scheme-handler/https text/html application/xhtml+xml; do
        gio mime "$mime" "$file"
    done
    notify "Default browser" "$file"
}

set_file_manager() {
    local choice file
    choice="$(choose_desktop "File Manager" '^MimeType=.*inode/directory')" || return 0
    file="${choice%%|*}"
    gio mime inode/directory "$file"
    notify "Default file manager" "$file"
}

set_editor() {
    local choice file path
    choice="$(choose_desktop "Editor" '^Categories=.*TextEditor')" || return 0
    file="${choice%%|*}"; path="${choice#*|}"
    gio mime text/plain "$file"
    local cmd
    cmd="$(desktop_exec "$path" 2>/dev/null || true)"
    write_defaults_env "${cmd:-$file}" ""
    notify "Default editor" "$file"
}

compositor_quit() {
    case "${XDG_CURRENT_DESKTOP:-}" in
        *niri*) niri msg action quit ;;
        *)
            if pgrep -x niri >/dev/null 2>&1; then niri msg action quit
            elif pgrep -x mango >/dev/null 2>&1; then pkill -TERM -x mango
            elif pgrep -x Hyprland >/dev/null 2>&1; then hyprctl dispatch exit
            else notify "smia-menu" "Unknown compositor; cannot log out"
            fi
            ;;
    esac
}

idle_daemon_pid() {
    pgrep -x hypridle 2>/dev/null | head -n1 || true
}

idle_inhibitor_status() {
    local pid
    pid="$(idle_daemon_pid)"
    [[ -z "$pid" ]] && { printf 'not running'; return; }
    local state
    state="$(ps -o state= -p "$pid" | tr -d ' ')"
    [[ "$state" == T* ]] && printf 'on' || printf 'off'
}

toggle_idle_inhibitor() {
    local pid
    pid="$(idle_daemon_pid)"
    if [[ -z "$pid" ]]; then
        notify "Idle inhibitor" "hypridle is not running"
        return 0
    fi
    local state
    state="$(ps -o state= -p "$pid" | tr -d ' ')"
    if [[ "$state" == T* ]]; then
        kill -CONT "$pid"
        notify "Idle Inhibitor" "Off"
    else
        kill -STOP "$pid"
        notify "Idle Inhibitor" "On"
    fi
}

dnd_active() {
    command -v makoctl >/dev/null 2>&1 && makoctl mode 2>/dev/null | grep -qx do-not-disturb
}

toggle_dnd() {
    if ! command -v makoctl >/dev/null 2>&1; then
        notify "smia-menu" "makoctl not found"
        return 0
    fi
    if dnd_active; then
        makoctl mode -r do-not-disturb
        notify "Do Not Disturb" "Off"
    else
        makoctl mode -a do-not-disturb
        notify "Do Not Disturb" "On"
    fi
}

current_theme() {
    local file="$XDG_CONFIG_HOME/gnist/themes/current.theme"
    [[ -r "$file" ]] && tr -d '[:space:]' < "$file" || printf 'unknown'
}

list_themes() {
    if [[ -d "$THEMES_DIR" ]]; then
        ls -1 "$THEMES_DIR"
    else
        printf '%s\n' \
            aeryn astral catppuccin catppuccin-latte ethereal \
            everforest flexoki-light gruvbox hackerman kanagawa \
            matte-black miasma nord osaka-jade ristretto rose-pine \
            tokyo-night vantablack white
    fi
}

themes_menu() {
    local current
    current="$(current_theme)"
    local choice
    choice="$(list_themes | pick "Theme: ${current}")" || return 1
    [[ "$choice" == "$current" ]] && { notify "Theme" "Already using $choice"; return 0; }
    setsid gnist set "$choice"
    notify "Theme" "Switched to $choice"
}

fmt_wallpaper_name() {
    local base="${1%.*}"
    base="${base##[0-9]*-}"
    base="${base//-/ }"
    printf '%s' "$base"
}

wallpaper_menu() {
    local backgrounds_dir="$XDG_CONFIG_HOME/gnist/themes/current/backgrounds"
    declare -A label_to_path
    local labels=()

    while IFS= read -r path; do
        local label
        label="$(fmt_wallpaper_name "$(basename "$path")")"
        label_to_path["$label"]="$path"
        labels+=("$label")
    done < <(find -L "$backgrounds_dir" -maxdepth 1 -type f \
        \( -name "*.jpg" -o -name "*.jpeg" -o -name "*.png" -o -name "*.webp" \) \
        | sort)

    [[ ${#labels[@]} -eq 0 ]] && { notify "Wallpaper" "No wallpapers found for current theme"; return 1; }

    local choice
    choice="$(printf '%s\n' "${labels[@]}" | pick "Wallpaper")" || return 1

    local path="${label_to_path[$choice]}"
    [[ -z "$path" ]] && return 1

    if ! gnist wallpaper "$path" >/dev/null 2>&1; then
        notify "Wallpaper" "Failed to apply $choice"
        return 1
    fi
    notify "Wallpaper" "$choice"
}

network_menu() {
    local choice
    choice="$(printf '%s\n' \
        "󰤨  WiFi / Network" \
        "󰂯  Bluetooth" \
        | pick "Network")" || return 1
    case "$choice" in
        *WiFi*)      xdg-terminal-exec impala ;;
        *Bluetooth*) xdg-terminal-exec bluetui ;;
    esac
}

profiles_menu() {
    local profiles
    if ! profiles="$(malm profiles --selectable | sed -n 's/^     //p')"; then
        notify "Profiles" "Failed to list profiles"
        return 1
    fi
    [[ -z "$profiles" ]] && { notify "Profiles" "No selectable profiles found"; return 1; }

    local profile label choice
    local labels=()
    declare -A label_to_profile
    while IFS= read -r profile; do
        case "$profile" in
            hyprland)        label="Hyprland" ;;
            hyprland-astral) label="Hyprland (Astral)" ;;
            mango)           label="Mango (Default)" ;;
            mango-astral)    label="Mango (Astral)" ;;
            niri)            label="Niri" ;;
            niri-astral)     label="Niri (Astral)" ;;
            *)               label="$profile" ;;
        esac
        labels+=("$label")
        label_to_profile["$label"]="$profile"
    done <<<"$profiles"

    choice="$(printf '%s\n' "${labels[@]}" | pick "Profiles")" || return 1
    profile="${label_to_profile[$choice]:-}"
    [[ -n "$profile" ]] || return 1
    smia-profile "$profile"
}

services_menu() {
    # Derive services from the manifest and module-owned fragments instead of
    # maintaining a separate daemon list.
    local manifest="$XDG_CONFIG_HOME/gnist/session.services"
    local frag_dir="$XDG_CONFIG_HOME/gnist/session.d"
    local entries=()
    declare -A proc_to_cmd

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*(#|$) ]] && continue
        local directive proc cmd label
        read -r directive rest <<<"$line"
        case "$directive" in
            restart)
                read -r proc cmd <<<"$rest"
                [[ -z "$cmd" ]] && cmd="$proc"
                case "$proc" in
                    waybar)             label="󰝘  Restart Waybar" ;;
                    mako)               label="󰂞  Restart Notifications" ;;
                    swayosd-server)     label="󰸉  Restart OSD" ;;
                    walker)             label="󰍉  Restart Walker" ;;
                    elephant)           label="󰈞  Restart Elephant" ;;
                    *)                  label="󰝘  Restart ${proc}" ;;
                esac
                # Keep one entry when multiple fragments name the same process.
                [[ -n "${proc_to_cmd[$label]:-}" ]] && continue
                entries+=("$label")
                proc_to_cmd["$label"]="$proc $cmd"
                ;;
        esac
    done < <({ [[ -r "$manifest" ]] && cat "$manifest"; [[ -d "$frag_dir" ]] && cat "$frag_dir"/* 2>/dev/null; })

    [[ ${#entries[@]} -eq 0 ]] && { notify "Services" "No services found in manifest"; return 1; }

    while true; do
        local choice
        choice="$(printf '%s\n' "${entries[@]}" | pick "Services")" || return 1
        local match="${proc_to_cmd[$choice]}"
        [[ -z "$match" ]] && continue
        local proc="${match%% *}"
        local cmd="${match#* }"

        pkill -x "$proc" 2>/dev/null || true
        # Allow the old process to exit before starting its replacement.
        for _ in $(seq 1 50); do
            pgrep -x "$proc" >/dev/null 2>&1 || break
            sleep 0.1
        done
        setsid sh -c "$cmd" >/tmp/smia-${proc}.log 2>&1 </dev/null &
        disown 2>/dev/null || true
        notify "Services" "$proc restarted"
    done
}

power_menu() {
    while true; do
        local choice
        choice="$(printf '%s\n' \
            "󰌾  Lock" \
            "󰒲  Suspend" \
            "󰑓  Reboot" \
            "󰚦  Shutdown" \
            "󰗼  Logout" \
            | pick "Power")" || return 1
        case "$choice" in
            *Lock*)     hyprlock ;;
            *Suspend*)  systemctl suspend ;;
            *Reboot*)   systemctl reboot ;;
            *Shutdown*) systemctl poweroff ;;
            *Logout*)   compositor_quit ;;
        esac
    done
}

defaults_menu() {
    while true; do
        local choice
        choice="$(printf '%s\n' \
            "󰆍  Terminal" \
            "󰖟  Browser" \
            "󰉋  File Manager" \
            "󰏤  Editor" \
            | pick "Defaults")" || return 1
        case "$choice" in
            *Terminal*)     set_terminal ;;
            *Browser*)      set_browser ;;
            *"File Manager"*) set_file_manager ;;
            *Editor*)       set_editor ;;
        esac
    done
}

toggles_menu() {
    while true; do
        local dnd_icon dnd_label idle_label
        if dnd_active; then
            dnd_icon="󰂚"; dnd_label="$dnd_icon  Do Not Disturb  [on]"
        else
            dnd_icon="󰂛"; dnd_label="$dnd_icon  Do Not Disturb  [off]"
        fi
        idle_label="󰒲  Idle Inhibitor  [$(idle_inhibitor_status)]"

        local choice
        choice="$(printf '%s\n' \
            "$dnd_label" \
            "$idle_label" \
            | pick "Toggles")" || return 1
        case "$choice" in
            *"Do Not Disturb"*) toggle_dnd ;;
            *"Idle Inhibitor"*) toggle_idle_inhibitor ;;
        esac
    done
}

main() {
    while true; do
        local choice
        choice="$(printf '%s\n' \
            "󰔡  Toggles" \
            "󰤨  Network" \
            "󰘧  Profiles" \
            "󰔨  Themes" \
            "󰸉  Wallpaper" \
            "󱔢  Defaults" \
            "󰣖  Services" \
            "󰐥  Power" \
            | pick "System")" || exit 0
        case "$choice" in
            *Toggles*)   toggles_menu || true ;;
            *Network*)   network_menu && break ;;
            *Profiles*)  profiles_menu && break ;;
            *Themes*)    themes_menu && break ;;
            *Wallpaper*) wallpaper_menu && break ;;
            *Defaults*)  defaults_menu || true ;;
            *Services*)  services_menu || true ;;
            *Power*)     power_menu || true ;;
        esac
    done
}

main "$@"

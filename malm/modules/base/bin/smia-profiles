#!/usr/bin/env bash

set -euo pipefail

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
SMIA_DESKTOP_STATE="${SMIA_DESKTOP_STATE:-default}"
COMPOSITOR_PROVIDERS=(mango niri hypr)

usage() {
    cat <<'EOF'
Usage: smia-profiles [list|current|select|switch PROFILE]

Commands:
  list             List selectable profile names (default)
  current          Print the active profile
  select           Choose and switch profile with Walker
  switch PROFILE   Apply a profile and refresh the session
EOF
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || {
        printf 'smia-profiles: %s not found in PATH\n' "$1" >&2
        exit 1
    }
}

profile_names() {
    local output line
    require_command malm
    if ! output="$(malm --state "$SMIA_DESKTOP_STATE" profiles --selectable)"; then
        printf 'smia-profiles: failed to list profiles\n' >&2
        return 1
    fi
    while IFS= read -r line; do
        [[ "$line" == "     "* ]] && printf '%s\n' "${line#     }"
    done <<<"$output"
}

current_profile() {
    local profile_file="$XDG_CONFIG_HOME/smia/profile" profile
    [[ -r "$profile_file" ]] || {
        printf 'smia-profiles: active profile not found: %s\n' "$profile_file" >&2
        return 1
    }
    IFS= read -r profile < "$profile_file" || true
    [[ -n "$profile" ]] || {
        printf 'smia-profiles: active profile is empty\n' >&2
        return 1
    }
    printf '%s\n' "$profile"
}

profile_vars() {
    malm --state "$SMIA_DESKTOP_STATE" --profile "$1" --json vars
}

profile_uses_provider() {
    local profile="$1" family="$2"
    [[ "$family" == hypr ]] && family=hyprland
    [[ "$profile" == "$family" || "$profile" == "$family"-* ]]
}

profile_compositor_provider() {
    local vars provider
    vars="$(profile_vars "$1")" || return 1
    # Malm's JSON lists resolved modules but does not currently include slots.
    for provider in "${COMPOSITOR_PROVIDERS[@]}"; do
        if [[ "$vars" == *"\"module\": \"$provider\""* ]]; then
            printf '%s\n' "$provider"
            return 0
        fi
    done
    return 1
}

running_compositor_provider() {
    local desktop
    for desktop in "${XDG_CURRENT_DESKTOP:-}" "${XDG_SESSION_DESKTOP:-}"; do
        case "${desktop,,}" in
            *mango*)     printf 'mango\n'; return 0 ;;
            *niri*)      printf 'niri\n'; return 0 ;;
            *hyprland*)  printf 'hypr\n'; return 0 ;;
        esac
    done

    if pgrep -x mango >/dev/null 2>&1; then printf 'mango\n'
    elif pgrep -x niri >/dev/null 2>&1; then printf 'niri\n'
    elif pgrep -x Hyprland >/dev/null 2>&1; then printf 'hypr\n'
    else return 1
    fi
}

current_compositor_provider() {
    local provider profile
    if provider="$(running_compositor_provider)"; then
        printf '%s\n' "$provider"
        return 0
    fi

    profile="$(current_profile)" || return 1
    profile_compositor_provider "$profile"
}

switch_profile() {
    local profile="$1"
    require_command malm
    require_command smia-session
    malm --state "$SMIA_DESKTOP_STATE" --profile "$profile" apply -y
    exec smia-session --apply-theme
}

select_profile() {
    require_command walker
    local profiles profile provider label choice menu_theme
    profiles="$(profile_names)"
    [[ -n "$profiles" ]] || {
        printf 'smia-profiles: no selectable profiles found\n' >&2
        return 1
    }

    provider="$(current_compositor_provider)" || {
        printf 'smia-profiles: unable to determine the current compositor provider\n' >&2
        return 1
    }

    local compatible_profiles=()
    while IFS= read -r profile; do
        profile_uses_provider "$profile" "$provider" || continue
        compatible_profiles+=("$profile")
    done <<<"$profiles"
    [[ ${#compatible_profiles[@]} -gt 0 ]] || {
        printf 'smia-profiles: no selectable profiles found for compositor provider %s\n' "$provider" >&2
        return 1
    }

    local labels=()
    declare -A label_to_profile
    for profile in "${compatible_profiles[@]}"; do
        case "$profile" in
            hyprland)        label="Hyprland" ;;
            hyprland-astral) label="Hyprland (Astral)" ;;
            mango)           label="Mango (Default)" ;;
            mango-astral)    label="Mango (Astral)" ;;
            mango-paper)     label="Mango (Paper)" ;;
            mango-void)      label="Mango (Void)" ;;
            niri)            label="Niri" ;;
            niri-astral)     label="Niri (Astral)" ;;
            *)               label="$profile" ;;
        esac
        labels+=("$label")
        label_to_profile["$label"]="$profile"
    done

    if [[ -r "$XDG_CONFIG_HOME/smia/menu-theme" ]]; then
        IFS= read -r menu_theme < "$XDG_CONFIG_HOME/smia/menu-theme" || true
    fi
    menu_theme="${menu_theme:-gnist-menu}"
    choice="$(printf '%s\n' "${labels[@]}" \
        | walker --dmenu --placeholder "Profiles" --theme "$menu_theme")" || return 1
    [[ -n "$choice" ]] || return 1
    profile="${label_to_profile[$choice]:-}"
    [[ -n "$profile" ]] || return 1
    switch_profile "$profile"
}

case "${1:-list}" in
    list)
        (($# <= 2)) || { printf 'usage: smia-profiles list [--names]\n' >&2; exit 2; }
        [[ "${2:-}" == "" || "${2:-}" == --names ]] \
            || { printf 'usage: smia-profiles list [--names]\n' >&2; exit 2; }
        profile_names
        ;;
    current)
        (($# == 1)) || { printf 'usage: smia-profiles current\n' >&2; exit 2; }
        current_profile
        ;;
    select)
        (($# == 1)) || { printf 'usage: smia-profiles select\n' >&2; exit 2; }
        select_profile
        ;;
    switch)
        (($# == 2)) || { printf 'usage: smia-profiles switch PROFILE\n' >&2; exit 2; }
        switch_profile "$2"
        ;;
    -h|--help)
        (($# == 1)) || { printf 'usage: smia-profiles --help\n' >&2; exit 2; }
        usage
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac

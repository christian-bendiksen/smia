// First-class facade for Gnist's installed theme data and Smia's per-profile
// metadata. Application modules own templates and reload bindings.
module "gnist" {
    description "Gnist theme data plus Smia profile, theme, and session metadata"
    slot "theme-runtime"

    requires {
        command "gnist"
    }

    inputs {
        input "default-theme" type="string" default="aeryn"
        input "menu-theme"    type="string" default="gnist-menu"
        input "stop-services" type="list" item-type="string" { default "dms" }
        input "extra-services" type="list" item-type="string"
    }

    outputs {
        // Own built-in themes independently so Gnist and user-installed themes
        // can coexist under the data root without whole-directory ownership.
        dir "gnist/themes/data/aeryn-gold" to="gnist/themes/data/aeryn-gold"
        dir "gnist/themes/data/aeryn" to="gnist/themes/data/aeryn"
        dir "gnist/themes/data/astral" to="gnist/themes/data/astral"
        dir "gnist/themes/data/catppuccin-latte" to="gnist/themes/data/catppuccin-latte"
        dir "gnist/themes/data/catppuccin" to="gnist/themes/data/catppuccin"
        dir "gnist/themes/data/ethereal" to="gnist/themes/data/ethereal"
        dir "gnist/themes/data/everforest" to="gnist/themes/data/everforest"
        dir "gnist/themes/data/flexoki-light" to="gnist/themes/data/flexoki-light"
        dir "gnist/themes/data/gruvbox" to="gnist/themes/data/gruvbox"
        dir "gnist/themes/data/hackerman" to="gnist/themes/data/hackerman"
        dir "gnist/themes/data/kanagawa" to="gnist/themes/data/kanagawa"
        dir "gnist/themes/data/matte-black" to="gnist/themes/data/matte-black"
        dir "gnist/themes/data/miasma" to="gnist/themes/data/miasma"
        dir "gnist/themes/data/nord" to="gnist/themes/data/nord"
        dir "gnist/themes/data/osaka-jade" to="gnist/themes/data/osaka-jade"
        dir "gnist/themes/data/paper" to="gnist/themes/data/paper"
        dir "gnist/themes/data/ristretto" to="gnist/themes/data/ristretto"
        dir "gnist/themes/data/rose-pine" to="gnist/themes/data/rose-pine"
        dir "gnist/themes/data/tokyo-night" to="gnist/themes/data/tokyo-night"
        dir "gnist/themes/data/vantablack" to="gnist/themes/data/vantablack"
        dir "gnist/themes/data/void" to="gnist/themes/data/void"
        dir "gnist/themes/data/white" to="gnist/themes/data/white"

        render "smia/profile" format="scalar" {
            @line (ref)"profile.name"
        }
        render "smia/default-theme" format="scalar" {
            @line (ref)"default-theme"
        }
        render "smia/menu-theme" format="scalar" {
            @line (ref)"menu-theme"
        }
        render "smia/session.services" format="line-list" {
            @comment "Generated by the `gnist` module; edits will be replaced."
            @comment "`smia-session` accepts these directives:"
            @comment "  prepare <proc> [command] starts a dependency unless proc is already running"
            @comment "  run <proc> [command]     starts command, or proc when omitted, unless proc is running"
            @comment "  restart <proc> [command] stops proc, waits for exit, then starts it as above"
            @comment "  stop <proc>              stops processes whose exact name is proc"
            @comment "Commands are passed to `sh -c`; proc and command are separated by whitespace."
            @line ""
            @each "service" in="stop-services" {
                @line (f)"stop {{service}}"
            }
            @each "line" in="extra-services" {
                @line (ref)"line"
            }
        }
    }
}

// Provides Bash startup files and a systemd environment.d drop-in. Aliases stay
// in a replaceable shell fragment so profile-specific quoting remains native.
module "shell" {
    description "Interactive bash environment: bashrc, profile, aliases, and the systemd environment.d drop-in"
    slot "shell"

    requires {
        command "bash"
    }

    inputs {
        input "editor"          type="string" default="hx"
        input "pager"           type="string" default="less -R"
        input "term"            type="string" default="kitty"
        input "history-size"    type="int"    default=100000
        input "history-control" type="enum" default="ignoreboth" {
            values "ignorespace" "ignoredups" "ignoreboth" "erasedups"
        }
    }

    fragments {
        fragment "aliases" format="shell" cardinality="one" {
            default "./alias.bash"
        }
    }

    outputs {
        render "~/.bashrc" format="text" validate="shell" {
            @file "./bashrc.tpl" interpolate=#true
        }
        render "~/.profile" format="text" validate="shell" {
            @file "./profile.tpl" interpolate=#true
        }
        render "~/.bashrc.d/alias.bash" format="text" validate="shell" {
            @compose "aliases"
        }
        render "~/.bashrc.d/smia-completion.bash" format="text" validate="shell" {
            @file "./smia-completion.bash"
        }

        // environment.d expands ${HOME}; keep the value unquoted as before.
        render "~/.config/environment.d/gnist.conf" format="key-value" separator="=" quote="none" {
            @comment "Generated by the shell module; edits will be replaced."
            @comment "smia-menu owns EDITOR, VISUAL, and TERMINAL defaults."
            "PATH" "${HOME}/.local/bin:/usr/local/bin:/usr/bin:/bin"
            "PAGER" (ref)"pager"
        }
    }
}

// This module owns wallpaper engine selection, startup, and session lifecycle.
// The engine enum drives the requirement gates directly. Engine values also
// serve as process names in the session manifest. Client-based engines are
// checked for readiness before receiving the selected image and resize mode.
// The mutable current-theme source allows `gnist set` to update the desktop
// without another Malm apply.
module "wallpaper" {
    description "Wallpaper engine selection, apply script and session fragment"
    slot "wallpaper-daemon"

    requires {
        command "pgrep"
        @when "engine" is="awww-daemon" {
            command "awww"
            command "awww-daemon"
        }
        @when "engine" is="swaybg" {
            command "swaybg"
        }
        @when "engine" is="swww-daemon" {
            command "swww"
            command "swww-daemon"
        }
        @when "engine" is="hyprpaper" {
            command "hyprpaper"
        }
    }

    inputs {
        // The engine identifier doubles as the managed process name.
        input "engine" type="enum" default="awww-daemon" {
            values "swaybg" "swww-daemon" "hyprpaper" "awww-daemon"
        }
        input "fill-mode" type="enum" default="fill" {
            values "stretch" "fill" "fit" "center" "tile"
        }
        input "image-src" type="path" default="~/.config/gnist/themes/background"
    }

    outputs {
        // The launcher maps the selected engine and fill mode to native commands.
        render "~/.local/bin/gnist-wallpaper-apply.sh" format="text" executable=#true validate="shell" {
            @file "./apply.sh.tpl" interpolate=#true
        }

        // smia-session combines this owner-specific fragment with the core
        // manifest and manages the process named by the engine input.
        render "gnist/session.d/wallpaper" format="line-list" {
            @line (f)"restart {{engine}}  gnist-wallpaper-apply.sh"
        }
    }
}
